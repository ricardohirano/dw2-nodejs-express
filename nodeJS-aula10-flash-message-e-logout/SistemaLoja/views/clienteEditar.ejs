<%- include ('partials/header.ejs') %>
<%- include ('partials/navbar.ejs') %>

<!-- pagina de edicao-->

<div class="containner">
    <div class="card">
        <div class="card-header">
            <h1>Alterar Cliente</h1>
            <hr>
        </div>
        <div class="card-body">
            <form action="/clientes/alterar" method="POST">
                <label>Nome do Cliente</label>
                <input type="text" name="nome" class="form-control" value="<%= cliente.nome %>" required>
                <label>CPF do Cliente</label>
                <input type="text" name="cpf" class="form-control" value="<%= cliente.cpf %>" required>
                <label>endereço do cliente</label>
                <input type="text" name="endereco" class="form-control" value="<%= cliente.endereco %>" required>
                <br>

                <!--Input type="hidden" escondida para armazenar o ID do cliente-->
                <input type="hidden" name="id" value="<%= cliente.id %>">
                <!--Botao de enviar-->
                <input type="submit" value="Alterar" class="btn btn-warning"> 
                <!--Botao de reset-->
                <input type="reset" value="Cancelar" class="btn btn-danger"> 

            </form>
        </div>
    </div>
</div>
    
<%- include ('partials/footer.ejs') %>